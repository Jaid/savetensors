{
  "name": "savetensors",
  "version": "0.1.0",
  "type": "module",
  "description": "gitless downloader for Hugging Face repositories",
  "funding": "https://github.com/sponsors/Jaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaid/savetensors.git"
  },
  "exports": {
    ".": {
      "types": "./src/main.ts",
      "default": "./src/main.ts"
    }
  },
  "bin": "./src/cli.ts",
  "imports": {
    "#src/*": "./src/*",
    "#root/*": "./*"
  },
  "scripts": {
    "build": "NODE_ENV=production build_lib"
  },
  "dependencies": {
    "@huggingface/hub": "^2.13.2",
    "chalk": "^5.6.2",
    "clerc": "^1.3.1",
    "forward-slash-path": "^0.3.0",
    "fs-extra": "^11.3.5",
    "hasha": "^7.0.0",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/picomatch": "^4.0.3",
    "bun-types": "^1.3.14",
    "eslint": "^10.5.0",
    "eslint-config-jaid": "^26.0.0",
    "tsconfig-jaid-bun": "^15.2.0",
    "typescript": "^6.0.3"
  }
}